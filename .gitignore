# ============================================================
# 🔒 .gitignore — Plataforma Herrería Aluminio
# Stack: Next.js 18 + FastAPI + PostgreSQL + Supabase + Docker
# ============================================================

# ── Entorno y variables secretas ──────────────────────────
.env
.env.*
!.env.example
*.local
*.secret

# ── Python (FastAPI + SQLAlchemy + Alembic) ───────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
.Python
venv/
venv*/
.venv/
ENV/
env/
*.egg-info/
dist/
build/
buildozer/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
coverage.xml
*.cover
*.py,cover
hypothesis/
.python-version
uv.lock
poetry.lock
Pipfile.lock

# Alembic (la DB local no se versiona)
alembic/versions/*.pyc

# Runtime
*.pid

# ── Node.js (Next.js + React + TypeScript) ────────────────
node_modules/
.next/
out/
build/
.vercel
.turbo
.nuxt
*.tsbuildinfo
*.js.map
.cache/
.eslintcache
.stylelintcache

# Output de build
dist-storybook/
storybook-static/

# ── Testing ──────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
cypress/downloads/
.lighthouseci/

# ── Docker ───────────────────────────────────────────────
docker-compose.override.yml
docker-compose.override.yaml
.dockerignore
*.tar

# ── Supabase ─────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/migrations/*.pyc

# ── IDE / Editores ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.cursor/
.cursorrules

# ── Sistema operativo ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Seguridad ────────────────────────────────────────────
*.pem
*.key
*.crt
*.cert
*.der
*.p12
*.pfx
credentials.json
secrets.yaml
*.env.secret
*.env.prod

# ── Archivos grandes y binarios ──────────────────────────
*.zip
*.tar.gz
*.tgz
*.7z
*.rar
*.pdf
*.docx
*.xlsx
*.pptx

# Imágenes generadas por el usuario (solo en desarrollo local)
uploads/
public/uploads/
storage/
*.generated.*

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Base de datos local (SQLite de desarrollo) ───────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── Entornos virtuales adicionales ───────────────────────
pip-wheel-metadata/
.pdm.toml
pdm.lock

# ── Terraform / Infraestructura (si se usa) ─────────────
*.tfstate
*.tfstate.*
.terraform/
override.tf
override.tf.json
.terraform.lock.hcl

# ── Misceláneos ─────────────────────────────────────────
*.bak
*.tmp
*.temp
*.old
*.orig
*.rej
*.patch  # parches generados localmente, no los subidos
tmp/
temp/

# ── Archivos generados por IA / caché ───────────────────
*.gen.png
*.gen.jpg
*.gen.svg
.cache/openai/
.cache/huggingface/
