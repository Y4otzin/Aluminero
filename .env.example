# ============================================================================
# 🔑 CREDENCIALES - Plataforma Herrería Aluminio
# ⚠️ COPIA ESTE ARCHIVO COMO .env Y LLENA LOS VALORES
# ============================================================================

# --- BASE DE DATOS ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://user:password@localhost:5432/aluminio_db

# --- AUTENTICACIÓN ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- EMAIL (Resend recomendado) ---
RESEND_API_KEY=
SENDGRID_FROM_EMAIL=noreply@tudominio.com

# --- IA (Renders) — ELIMINADO: ahora usamos generador interno de boceto SVG (app/api/v1/sketch.py)
# No se requieren APIs externas para la visualización.

# --- ALMACENAMIENTO ---
SUPABASE_STORAGE_BUCKET=project-files
SIGNED_URL_EXPIRATION_SECONDS=3600

# --- INFRAESTRUCTURA ---
RAILWAY_TOKEN=
DOMAIN=
SSL_EMAIL=

# --- MONITOREO ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- APP ---
APP_ENV=development
APP_SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:3000
IVA_RATE=0.16
MAX_RENDERS_PER_PROJECT=5
MAX_FILE_SIZE_MB=10
